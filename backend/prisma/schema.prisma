// =============================================================================
// GENERATOR & DATASOURCE
// =============================================================================

generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")      // Used by Prisma Client at runtime
  directUrl = env("DIRECT_URL")       // Used for migrations and introspection
}

// =============================================================================
// ENUM DEFINITIONS
// =============================================================================


// ==================== USER enums ====================  
enum Role {
  ADMIN      
  LANDLORD   
  TENANT     
}


// ==================== PROPERTY enums ====================  
enum PropertyType {
  APARTMENT   
  CONDOMINIUM 
  BOARDING_HOUSE
  SINGLE_HOUSE
}


// ==================== UNIT enums ====================  
enum UnitStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}


// ==================== LEASE enums ====================  
enum RentInterval {
  DAILY       
  WEEKLY      
  MONTHLY     
  ANNUALLY    
}


enum LeaseStatus {
  PENDING     
  ACTIVE      
  TERMINATED  
  COMPLETED   
}


// ==================== PAYMENT enums ====================  
enum PaymentMethod {
  CASH
  GCASH
  BANK_TRANSFER
  CREDIT_CARD
  OTHER
}


// ==================== MAINTENANCE enums ====================  
enum RequestStatus {
  OPEN         
  IN_PROGRESS  
  RESOLVED     
}


// ==================== NOTIFICATION enums ====================  
enum NotificationType {
  GENERAL       
  PAYMENT       
  MAINTENANCE   
  INVITATION    
}


// ==================== APPLICATION enums ====================  
enum ApplicationStatus {
  PENDING     
  REVIEWED    
  APPROVED    
  REJECTED    
  WITHDRAWN   
}

// ======================================================================================================
// MODELS
// ======================================================================================================

// ==================== User Models ====================  
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     

  // Account status 
  isVerified   Boolean  @default(false)    // email verification
  isDisabled   Boolean  @default(false)    

  // Timestamps & tokens
  RefreshToken      RefreshToken[]         
  createdAt    DateTime @default(now())
  
  // Other User Information
  UserProfile      UserProfile?            
  ContactInfo      UserContactInfo?        

  // Relations
  Property            Property[]           
  Lease               Lease[]              
  MaintenanceRequest  MaintenanceRequest[] 
  Notification        Notification[]       


  @@map("users")
  @@index([email])
  @@index([role])
  Application Application[]
  UnitReview UnitReview[]
}


model RefreshToken {
  id         String   @id @default(uuid())
  tokenHash  String   @unique  // Hashed token
  createdAt  DateTime @default(now())
  expiresAt  DateTime          // Expiration timestamp
  isRevoked  Boolean  @default(false)

  // Relation 
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String

  @@map("refresh_tokens")
  @@index([userId])
  @@index([expiresAt])
}


model UserProfile {
  userId    String   @id
  firstName String
  lastName  String
  avatarUrl String?  // Optional profile picture

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}


model UserContactInfo {
  userId       String @id
  phoneNumber  String? 
  messengerUrl String? 
  facebookUrl  String? 
  

  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// -------------------- City / Municipality --------------------
model CityMunicipality {
  id         String     @id @default(uuid())
  name       String     @unique                  // e.g., "Cebu City", "Toledo", "Mandaue"
  properties Property[]                           // All properties in this city
}
// ==================== PROPERTY ====================
model Property {
  id        String   @id @default(uuid())
  ownerId   String

  title       String
  description String
  type        PropertyType @default(APARTMENT)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // --- Address ---
  street      String
  barangay    String
  province    String
  zipCode     String?

  cityId      String
  city        CityMunicipality @relation(fields: [cityId], references: [id])

  // --- Amenities & Media ---
  amenityTags      Json?              // General nearby perks (e.g., "Near UC Main")
  leaseRules       Json?              // Property-wide rules
  propertyImageUrls Json?
  mainImageUrl     String?

  requiresScreening Boolean @default(false)

  // --- Relations ---
  owner              User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  Unit               Unit[]
  MaintenanceRequest MaintenanceRequest[]
  Income             Income[]
  Expense            Expense[]
  Application        Application[]

  @@map("properties")
  @@index([id])
  @@index([cityId])
}

// ==================== UNIT ====================
model Unit {
  id             String   @default(uuid()) @unique
  propertyId     String

  // --- Info ---
  label          String
  description    String
  status         UnitStatus @default(AVAILABLE)
  floorNumber    Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // --- Layout & Features ---
  maxOccupancy   Int @default(1)
  unitFeatureTags Json?           // Room-specific features (e.g., "wifi", "aircon")
  unitImageUrls   Json?           // Photos specific to this unit
  unitLeaseRules  Json?           // Lease-specific rules

  // --- Pricing & Listing ---
  targetPrice    Float
  isListed       Boolean @default(false)

  // --- Relations ---
  property           Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  Lease              Lease[]
  MaintenanceRequest MaintenanceRequest[]
  Application        Application[]
  UnitReview         UnitReview[]

  @@map("units")
  @@id([propertyId, id])
  @@index([id])
  @@unique([propertyId, label])
}

// ==================== UNIT REVIEW ====================
model UnitReview {
  id        String   @id @default(uuid())
  tenantId  String
  unitId    String
  leaseId   String

  rating    Float               // 1.0 - 5.0 rating, e.g., 2.8
  comment   String?             // Optional review comment
  createdAt DateTime @default(now())

  // --- Relations ---
  tenant User @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit   Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  lease  Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@unique([tenantId, unitId, leaseId])
  @@map("unit_reviews")
}



// ==================== Lease Models ==================== 
model Lease {
  // Primary identity
  id         String       @id @default(uuid())
  unitId     String       @unique   // One active lease per unit
  tenantId   String       // Must be a TENANT user

  // Term dates
  startDate  DateTime
  endDate    DateTime

  // Financial terms
  rentAmount     Float
  interval       RentInterval @default(MONTHLY)
  initialDeposit Float?        // Optional security deposit

  // Lifecycle
  status          LeaseStatus  @default(PENDING)
  inviteToken     String?      // For sharing invite link
  inviteExpiresAt DateTime?

  pdfUrl        String?   // URL to generated lease PDF

  // Auditing
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  unit             Unit             @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenant           User             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  Payment          Payment[]
  ScheduledPayment ScheduledPayment[]

  @@map("scheduled_payments")
  UnitReview UnitReview[]
}


// ==================== Payment Models ==================== 
model Payment {
  // Primary key & monetary info
  id       String   @id @default(uuid())
  leaseId  String
  amount   Float
  paidAt   DateTime @default(now())
  method   PaymentMethod?
  note     String?
  photoUrl String?

  // Auditing
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  lease        Lease            @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  ScheduledPayment ScheduledPayment[]

  @@map("payments")
}

model ScheduledPayment {
  // Plan vs actual
  id        String   @id @default(uuid())
  leaseId   String
  dueDate   DateTime
  amount    Float
  isPaid    Boolean  @default(false)
  paymentId String?  // FK when paid

  // Auditing
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  lease   Lease    @relation(fields: [leaseId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])

  @@index([leaseId, dueDate])
}





// ==================== Maintenance Models ==================== 
model MaintenanceRequest {
  // Identity & description
  id          String        @id @default(uuid())
  propertyId  String
  unitId      String?
  reporterId  String
  description String
  photoUrl    String?

  // Priority & status
  status   RequestStatus @default(OPEN)

  // Auditing
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  property  Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit      Unit?    @relation(fields: [unitId], references: [id], onDelete: Cascade)
  reporter  User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@map("maintenance_requests")
}


model Income {
  id         String   @id @default(uuid())
  propertyId String   // FK → Property.id
  amount     Float
  description String  // e.g. “rent”, “late fee”
  date       DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  @@map("incomes")
}


model Expense {
  id         String   @id @default(uuid())
  propertyId String
  amount     Float
  description String
  date       DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  @@map("expenses")
}



// ==================== Notification Models ==================== 
model Notification {
  id        String           @id @default(uuid())
  userId    String
  message   String
  type      NotificationType @default(GENERAL)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("notifications")
}


// ==================== Application Models ==================== 
model Application {
  id            String             @id @default(uuid())
  tenantId      String
  propertyId    String
  unitId        String            
  status        ApplicationStatus  @default(PENDING)

  // Tenant info (explicit capture)
  fullName      String             // tenant full name for this application
  contactEmail  String             // tenant contact email (can differ from account)
  contactPhone  String?            // optional phone number
  contactFacebook String?          // optional Facebook URL or ID
  contactMessenger String?         // optional Messenger URL or ID

  // Inquiry Details
  occupants     Int                @default(1)
  moveInDate    DateTime?         
  lengthOfStay  String?            // e.g. "6 months", "1 year" 
  message       String?            // Custom message or cover letter 

  // Specific questions tenant wants to ask landlord or info tenant needs
  questions     Json?              // Store flexible question-answer pairs

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  tenant        User     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit       Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@map("applications")
}










