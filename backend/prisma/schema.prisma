// =============================================================================
// GENERATOR & DATASOURCE
// =============================================================================

generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")      // Used by Prisma Client at runtime
  directUrl = env("DIRECT_URL")       // Used for migrations and introspection
}

// =============================================================================
// ENUM DEFINITIONS
// =============================================================================


// ==================== USER enums ====================  
enum Role {
  ADMIN      
  LANDLORD   
  TENANT     
}


// ==================== PROPERTY enums ====================  
enum PropertyType {
  APARTMENT   
  CONDOMINIUM 
  BOARDING_HOUSE
  SINGLE_HOUSE
}


// ==================== UNIT enums ====================  
enum UnitStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}


// ==================== LEASE enums ====================  
enum RentInterval {
  DAILY       
  WEEKLY      
  MONTHLY     
  ANNUALLY    
}


enum LeaseStatus {
  PENDING     
  ACTIVE      
  TERMINATED  
  COMPLETED   
}


// ==================== PAYMENT enums ====================  
enum PaymentMethod {
  CASH
  GCASH
  BANK_TRANSFER
  CREDIT_CARD
  OTHER
}


// ==================== MAINTENANCE enums ====================  
enum RequestStatus {
  OPEN         
  IN_PROGRESS  
  RESOLVED     
}


// ==================== NOTIFICATION enums ====================  
enum NotificationType {
  GENERAL       
  PAYMENT       
  MAINTENANCE   
  INVITATION    
}


// ==================== APPLICATION enums ====================  
enum ApplicationStatus {
  PENDING     
  REVIEWED    
  APPROVED    
  REJECTED    
  WITHDRAWN   
}

// ======================================================================================================
// MODELS
// ======================================================================================================

// ==================== User Models ====================  
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     

  // Account status 
  isVerified   Boolean  @default(false)    // email verification
  isDisabled   Boolean  @default(false)    

  // Timestamps & tokens
  RefreshToken      RefreshToken[]         
  createdAt    DateTime @default(now())
  
  // Other User Information
  UserProfile      UserProfile?            
  ContactInfo      UserContactInfo?        

  // Relations
  Property            Property[]           
  Lease               Lease[]              
  MaintenanceRequest  MaintenanceRequest[] 
  Notification        Notification[]       


  @@map("users")
  @@index([email])
  @@index([role])
  Application Application[]
}


model RefreshToken {
  id         String   @id @default(uuid())
  tokenHash  String   @unique  // Hashed token
  createdAt  DateTime @default(now())
  expiresAt  DateTime          // Expiration timestamp
  isRevoked  Boolean  @default(false)

  // Relation 
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String

  @@map("refresh_tokens")
  @@index([userId])
  @@index([expiresAt])
}


model UserProfile {
  userId    String   @id
  firstName String
  lastName  String
  avatarUrl String?  // Optional profile picture

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}


model UserContactInfo {
  userId       String @id
  phoneNumber  String? 
  messengerUrl String? 
  facebookUrl  String? 
  

  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}


// ==================== PROPERTY & UNIT MODELS ====================  
model Property {
  id               String   @id @default(uuid())        // Unique ID for the property
  ownerId          String                               // Reference to landlord (User)

  title            String                               // Property title or name
  description      String                               // Short description of the property
  type             PropertyType @default(APARTMENT)     // Type of property (APARTMENT, BOARDING_HOUSE, SINGLE_HOUSE, CONDOMINIUM.)
  createdAt        DateTime @default(now())             // Timestamp when record was created
  updatedAt        DateTime @updatedAt                  // Timestamp when record was last updated

  // --- Address (shared by all units in this property) ---
  street           String                               // Street address
  barangay         String                               // Barangay/district
  municipality     String?                              // Municipality (optional)
  city             String?                              // City (optional)
  province         String                               // Province
  zipCode          String                               // Postal code

  // --- Features & Rules (apply to entire property) ---
  amenityTags      Json?                                // Nearby/area perks (≤4 words each) e.g. “Near UC Main”
  propertyFeatures Json?                                // Shared features (2 words each) e.g. “with sofa”, “piso wifi”
  leaseRules       Json?                                // Property-wide rules e.g. “No smoking”, “Quiet after 10PM” 

  // --- Media ---
  propertyImageUrls Json?                               // Up to 5 images (main image included, same folder)
  mainImageUrl     String?                              // Featured image for quick display 

  // --- Listing Settings ---
  requiresScreening Boolean @default(false)             // If tenant screening is required

  // --- Relations ---
  owner              User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  Unit               Unit[]                              // All units/rooms in this property
  MaintenanceRequest MaintenanceRequest[]
  Income             Income[]
  Expense            Expense[]
  Application        Application[]

  // --- DB Mapping ---
  @@map("properties")
  @@index([id])
}


model Unit {
  id             String   @default(uuid()) @unique      // Unique ID for the unit
  propertyId     String                                 // Links back to parent property

  // --- Info ---
  label          String                                 // Unit name/label (e.g. “Room A”, “Unit 201”)
  description    String                                 // Short description of the unit
  status         UnitStatus @default(AVAILABLE)         // Availability status (e.g. AVAILABLE, OCCUPIED, MAINTENANCE)
  floorNumber    Int?                                   // Which floor this unit is on
  createdAt      DateTime @default(now())               // Created timestamp
  updatedAt      DateTime @updatedAt                    // Updated timestamp

  // --- Unit Layout ---
  maxOccupancy   Int @default(1)                        // How many people the unit can accommodate

  // --- Unit-Specific Features ---
  unitFeatureTags Json?                                 // Room-only features (1 word each) e.g. “aircon”, “wifi”
  unitImageUrls   Json?                                 // Photos specific to this unit (max 3)
  unitLeaseRules  Json?                                 // Unit-specific lease policies: "6 months term only", "Need Downpayment", "1 year minimum stay", 20 words limit only

  // --- Pricing ---
  targetPrice    Float                                  // Target monthly rent
  isNegotiable   Boolean @default(false)                // Can price be negotiated?

  // -- Listing ---
  isListed          Boolean @default(false)             // Whether unit is visible/active 

  // --- Relations ---
  property           Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  Lease              Lease[]
  MaintenanceRequest MaintenanceRequest[]
  Application        Application[]
  
  // --- DB Mapping ---
  @@map("units")
  @@id([propertyId, id])
  @@index([id])
  @@unique([propertyId, label])
}



// ==================== Lease Models ==================== 
model Lease {
  // Primary identity
  id         String       @id @default(uuid())
  unitId     String       @unique   // One active lease per unit
  tenantId   String       // Must be a TENANT user

  // Term dates
  startDate  DateTime
  endDate    DateTime

  // Financial terms
  rentAmount     Float
  interval       RentInterval @default(MONTHLY)
  initialDeposit Float?        // Optional security deposit

  // Lifecycle
  status          LeaseStatus  @default(PENDING)
  inviteToken     String?      // For sharing invite link
  inviteExpiresAt DateTime?

  pdfUrl        String?   // URL to generated lease PDF

  // Auditing
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  unit             Unit             @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenant           User             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  Payment          Payment[]
  ScheduledPayment ScheduledPayment[]

  @@map("scheduled_payments")
}


// ==================== Payment Models ==================== 
model Payment {
  // Primary key & monetary info
  id       String   @id @default(uuid())
  leaseId  String
  amount   Float
  paidAt   DateTime @default(now())
  method   PaymentMethod?
  note     String?
  photoUrl String?

  // Auditing
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  lease        Lease            @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  ScheduledPayment ScheduledPayment[]

  @@map("payments")
}

model ScheduledPayment {
  // Plan vs actual
  id        String   @id @default(uuid())
  leaseId   String
  dueDate   DateTime
  amount    Float
  isPaid    Boolean  @default(false)
  paymentId String?  // FK when paid

  // Auditing
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  lease   Lease    @relation(fields: [leaseId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])

  @@index([leaseId, dueDate])
}





// ==================== Maintenance Models ==================== 
model MaintenanceRequest {
  // Identity & description
  id          String        @id @default(uuid())
  propertyId  String
  unitId      String?
  reporterId  String
  description String
  photoUrl    String?

  // Priority & status
  status   RequestStatus @default(OPEN)

  // Auditing
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  property  Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit      Unit?    @relation(fields: [unitId], references: [id], onDelete: Cascade)
  reporter  User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@map("maintenance_requests")
}


model Income {
  id         String   @id @default(uuid())
  propertyId String   // FK → Property.id
  amount     Float
  description String  // e.g. “rent”, “late fee”
  date       DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  @@map("incomes")
}


model Expense {
  id         String   @id @default(uuid())
  propertyId String
  amount     Float
  description String
  date       DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  @@map("expenses")
}



// ==================== Notification Models ==================== 
model Notification {
  id        String           @id @default(uuid())
  userId    String
  message   String
  type      NotificationType @default(GENERAL)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("notifications")
}


// ==================== Application Models ==================== 
model Application {
  id            String             @id @default(uuid())
  tenantId      String
  propertyId    String
  unitId        String            
  status        ApplicationStatus  @default(PENDING)

  // Tenant info (explicit capture)
  fullName      String             // tenant full name for this application
  contactEmail  String             // tenant contact email (can differ from account)
  contactPhone  String?            // optional phone number
  contactFacebook String?          // optional Facebook URL or ID
  contactMessenger String?         // optional Messenger URL or ID

  // Inquiry Details
  occupants     Int                @default(1)
  moveInDate    DateTime?         
  lengthOfStay  String?            // e.g. "6 months", "1 year" 
  message       String?            // Custom message or cover letter 

  // Specific questions tenant wants to ask landlord or info tenant needs
  questions     Json?              // Store flexible question-answer pairs

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  tenant        User     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit       Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@map("applications")
}










